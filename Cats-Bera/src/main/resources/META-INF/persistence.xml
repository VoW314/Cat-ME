<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!-- Created by Osman Balci. Adapted by Shreyas Bera-->
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_2.xsd"
             version="3.2">

    <persistence-unit name="Cats-BeraPU" transaction-type="JTA">

        <jta-data-source>java:/CatsDB</jta-data-source>

        <exclude-unlisted-classes>false</exclude-unlisted-classes>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url"  value="jdbc:mysql://localhost:3306/CatsDB"/>
            <property name="jakarta.persistence.jdbc.user"  value="root"/>
            <property name="jakarta.persistence.jdbc.password"  value="CSD@mysql-1872"/>
            <property name="jakarta.persistence.schema-generation.database.action" value="none"/>
        </properties>

    </persistence-unit>
</persistence>